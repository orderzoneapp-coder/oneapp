    {
      "id": "image-generator",
      "name": "Image Generator",
      "proposedPath": "image_generator.html",
      "kind": "utility",
      "status": "planned",
      "developmentState": "on-hold",
      "purpose": "Create offline-sales images and print materials for market-price changes and promotional products.",
      "owner": "sales-output-roadmap",
      "inputs": [
        "MerchOps F9 review payload",
        "approved product and promotion information"
      ],
      "outputs": [
        "offline sales image",
        "print-ready sales material"
      ],
      "sharedContracts": [
        "product-master"
      ],
      "upstream": [
        "merchops",
        "export-center"
      ],
      "downstream": [
        "print-output"
      ],
      "productionWrites": false,
      "workflowIntent": "MerchOps F9 review leads to a downstream F10 print action after the output workflow is approved.",
      "validation": [
        "Printed values match the approved review payload.",
        "Preview and print layouts remain legible at the target paper size.",
        "Image generation cannot mutate product master data."
      ],
      "rollback": "Disable the pilot output entry and continue using existing Excel or manual print output.",
      "targetStatus": "pilot",
      "resumeAfter": [
        "MerchOps Export Center workflow is stable.",
        "Output and print validation rules are approved."
      ]
    }
  ],
  "recoveryPolicy": {
    "sourceOfTruth": "Git history and the main branch",
    "preferredMethods": [
      "stable-tag",
      "pull-request-revert",
      "rollback-pull-request"
    ],
    "testCopiesAreBackups": false,
    "optionalPreviewPolicy": "Keep at most one explicitly named preview or stable entry point per operational need, with an owner and verification date."
  },
  "functionKeyPolicy": {
    "applicationOwned": true,
    "crossApplicationSemanticUnification": false,
    "assignments": {
      "merchops": {
        "F8": "Apply current work to the master and create the immediate Excel output.",
        "F9": "Open Export Center for review and downstream output."
      },
      "dataops": {
        "F8": "Unassigned.",
        "F9": "Create the combined workbook output.",
        "F10": "Open the print output workflow."
      }
    }
  },
  "developmentRoadmap": [
    {
      "phase": 1,
      "name": "Baseline and checks",
      "scope": [
        "inventory production entry points",
        "record shared contracts",
        "define application-specific smoke tests"
      ]
    },
    {
      "phase": 2,
      "name": "Client safety",
      "status": "in-progress",
      "scope": [
        "validate imports before apply",
        "protect browser storage writes",
        "show actionable errors"
      ],
      "delivered": [
        "block master Excel apply when rows have missing or duplicate product codes",
        "limit master imports to supported file types, 25 MB, and 100000 rows",
        "verify shared storage writes and automatically restore master/history after an apply failure",
        "show persistent actionable errors in the master database management screen"
      ]
    },
    {
      "phase": 3,
      "name": "Cloud protection",
      "scope": [
        "validate cloud actions and payloads",
        "protect restore paths",
        "improve failure reporting"
      ]
    },
    {
      "phase": 4,
      "name": "Atomic backup and rollback",
      "scope": [
        "version stable releases",
        "verify rollback procedure",
        "avoid duplicate recovery files"
      ]
    },
    {
      "phase": 5,
      "name": "Application-specific output stability",
      "subphases": [
        {
          "id": "5A",
          "application": "merchops",
          "shortcuts": {
            "F8": "Apply current work to the master and create the immediate Excel output.",
            "F9": "Open Export Center for review and downstream output."
          }
        },
        {
          "id": "5B",
          "application": "dataops",
          "shortcuts": {
            "F8": "Unassigned.",
            "F9": "Create the combined workbook output.",
            "F10": "Open the print output workflow."
          }
        }
      ],
      "sharedOnly": [
        "validation",
        "backup",
        "download status",
        "audit utilities"
      ],
      "constraint": "Do not unify application-specific business semantics merely because the same function key is used."
    },
    {
      "phase": 6,
      "name": "Dependency and shared-engine hardening",
      "scope": [
        "remove unsafe duplication only after compatibility tests",
        "document migrations",
        "protect application-owned workflows"
      ]
    }
  ]
}
